Submitted By:            still-image addendum (apply after svt_av1_build_fix-1.patch)
Date:                    2025-03-20
Initial Package Version: 1.21.2
Origin:                  Addendum to libheif-1.21.2-svt_av1_build_fix-1.patch
Upstream Status:         Not submitted
Description:             Enables proper AVIF still image mode for the SVT-AV1 encoder
                         backend in libheif.  Without this patch libheif/SVT-AV1 produces
                         files with a video-oriented GOP structure, causing:
                           - Firefox to refuse display ("contains errors") due to missing
                             mif1/miaf compatible_brands and pixi box (MIAF §3.6.6)
                           - Higher memory usage during encode (TPL lookahead buffers)
                         Apply this patch AFTER svt_av1_build_fix-1.patch.

diff -Naur libheif-1.21.2.orig/libheif/plugins/encoder_svt.cc libheif-1.21.2/libheif/plugins/encoder_svt.cc
--- libheif-1.21.2.orig/libheif/plugins/encoder_svt.cc
+++ libheif-1.21.2/libheif/plugins/encoder_svt.cc
@@ -1,3 +1,5 @@
+// NOTE: apply after svt_av1_build_fix-1.patch
+
 /*
  * HEIF codec.
  * Copyright (c) 2023 Dirk Farin <dirk.farin@gmail.com>
@@ -155,6 +157,42 @@ static struct heif_error svt_encode_image(void* encoder_raw,
   enc->svt_config.source_width  = (uint32_t)width;
   enc->svt_config.source_height = (uint32_t)height;
 
+  // ------------------------------------------------------------------
+  // Still image mode.
+  //
+  // Without these settings SVT-AV1 defaults to a video GOP structure.
+  // Firefox (mp4parse-rust) strictly validates MIAF brands: a sequence-
+  // oriented file (major_brand=avis, no pitm still item) is rejected
+  // with "image contains errors".  Memory usage is also higher because
+  // the encoder allocates TPL lookahead buffers for future frames that
+  // never arrive.
+  //
+  // intra_period_length = -1
+  //   No inter prediction; encoder produces only intra (I) frames.
+  //   Equivalent to --keyint -1 on the CLI.
+  //
+  // force_key_frames = 1
+  //   Marks every submitted frame as a key frame at the API level,
+  //   redundant with intra_period_length=-1 but makes intent explicit.
+  //
+  // enable_tpl_la = 0
+  //   Disables Temporal Pattern Lookahead.  TPL requires a sliding
+  //   window of future frames to work; with a single still frame it
+  //   only wastes memory and adds latency.
+  //
+  // hierarchical_levels = 0
+  //   Flat prediction hierarchy; no B-frame pyramid needed for one frame.
+  //
+  // pred_structure = SVT_AV1_PRED_LOW_DELAY_P
+  //   Simplest prediction structure, no reordering buffer.
+  // ------------------------------------------------------------------
+  enc->svt_config.intra_period_length = -1;
+  enc->svt_config.force_key_frames    = 1;
+  enc->svt_config.enable_tpl_la       = 0;
+  enc->svt_config.hierarchical_levels = 0;
+  enc->svt_config.pred_structure      = SVT_AV1_PRED_LOW_DELAY_P;
+
+  // Nominal frame rate — required by SVT-AV1 init even for stills.
+  enc->svt_config.frame_rate_numerator   = 1;
+  enc->svt_config.frame_rate_denominator = 1;
+
   // color format
   heif_chroma chroma = heif_image_get_chroma_format(image);
   int bit_depth = heif_image_get_bits_per_pixel_range(image, heif_channel_Y);
@@ -215,7 +253,11 @@ static struct heif_error svt_encode_image(void* encoder_raw,
   input_buf->p_app_private = nullptr;
   input_buf->pic_type      = EB_AV1_KEY_PICTURE;
   input_buf->pts           = 0;
-  input_buf->flags         = 0;
+  // Set EOS on the frame itself rather than sending a separate EOS
+  // packet afterwards.  In SVT-AV1 >= 1.0 a separate EOS packet after
+  // EB_BUFFERFLAG_EOS causes a double-flush and may corrupt output.
+  input_buf->flags         = EB_BUFFERFLAG_EOS;
 
   res = svt_av1_enc_send_picture(enc->svt_handle, input_buf);
   if (res != EB_ErrorNone) {
@@ -226,13 +268,9 @@ static struct heif_error svt_encode_image(void* encoder_raw,
     return {heif_error_Encoder_plugin_error, heif_suberror_Encoder_encoding, "send_picture failed"};
   }
 
-  // send EOS
-  EbBufferHeaderType eos = {};
-  eos.flags    = EB_BUFFERFLAG_EOS;
-  eos.pic_type = EB_AV1_INVALID_PICTURE;
-  svt_av1_enc_send_picture(enc->svt_handle, &eos);
-
   // receive packets
   for (;;) {
