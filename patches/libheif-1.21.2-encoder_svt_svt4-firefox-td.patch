Origin:                  Upstream (PR #1680) + local fixes
Description:             Fixes building libheif with SVT-AV1 4.0 and later.

                         1. Still image mode (SVT-AV1 >= 4.0.0):
                            intra_period_length=-1, pred_structure, hierarchical_levels,
                            fps=1/1. Do NOT set svt_config.avif (Firefox often fails even
                            when w/h are even if avif=true).

                         2. tune=SSIM fallback to PSNR (SVT-AV1 >= 4.0.0).

                         3. Strip Temporal Delimiter OBU from output bitstream (AVIF §2.1).

                         4. Round DOWN odd dimensions in svt_query_encoded_size (clap / Firefox).

--- a/libheif/plugins/encoder_svt.cc
+++ b/libheif/plugins/encoder_svt.cc
@@ -666,11 +666,16 @@ void svt_query_encoded_size(void* encode
 
   // SVT-AV1 (as of version 1.2.1) can only create image sizes matching the chroma format. Add padding if necessary.
 
+  // Round DOWN for odd dimensions instead of up.
+  // Rounding up (input+1) causes libheif to add a clap box with offset=-(1/2)
+  // pixel — a non-integer offset that Firefox rejects per AVIF spec ISO 23000-22.
+  // Rounding down means encoded<=input: libheif skips the clap box entirely.
+  // The single lost pixel on odd-sized images is imperceptible.
   if (input_width < 64) {
     *encoded_width = 64;
   }
   else if (encoder->chroma == heif_chroma_420 && (input_width & 1) == 1) {
-    *encoded_width = input_width + 1;
+    *encoded_width = input_width - 1;
   }
   else {
     *encoded_width = input_width;
@@ -680,7 +685,7 @@ void svt_query_encoded_size(void* encode
     *encoded_height = 64;
   }
   else if (encoder->chroma != heif_chroma_444 && (input_height & 1) == 1) {
-    *encoded_height = input_height + 1;
+    *encoded_height = input_height - 1;
   }
   else {
     *encoded_height = input_height;
@@ -829,8 +834,15 @@ static heif_error svt_start_sequence_enc
   svt_config.tile_columns = int_log2(encoder->tile_cols);
 
 #if SVT_AV1_CHECK_VERSION(0, 9, 1)
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+  // tune=SSIM requires CRF in SVT-AV1 4.x; libheif uses CQP - fall back to PSNR
+  svt_config.tune = (encoder->tune == encoder_struct_svt::Tune_SSIM)
+                    ? encoder_struct_svt::Tune_PSNR
+                    : encoder->tune;
+#else
   svt_config.tune = encoder->tune;
 #endif
+#endif
 
   svt_config.enc_mode = (int8_t) encoder->speed;
 
