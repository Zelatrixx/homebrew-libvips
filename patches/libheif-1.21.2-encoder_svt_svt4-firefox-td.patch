         output_packet.frameNr = output_buf->pts;
         output_packet.is_keyframe = (output_buf->pic_type == EbAv1PictureType::EB_AV1_KEY_PICTURE);
 
+        // Strip Temporal Delimiter OBU (type=2) from output bitstream.
+        // AVIF spec (ISO 23000-22 section 2.1) forbids TD OBUs in image items.
+        // Some SVT outputs prepend one; Firefox rejects TD in image items.
+        // TD OBU is always 2 bytes: header byte (0x12) + size byte (0x00).
+        uint32_t strip = (n >= 2 && ((data[0] >> 3) & 0xF) == 2) ? 2 : 0;
+
