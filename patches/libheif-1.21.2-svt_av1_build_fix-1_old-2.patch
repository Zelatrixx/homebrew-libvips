Submitted By:            Combined: Douglas R. Reno (build fix) + still image fix
Date:                    2026-03-20
Initial Package Version: 1.21.2
Upstream Status:         Pending
Origin:                  Upstream (PR #1680) + explicit still image parameters
Description:             Fixes building libheif with SVT-AV1 4.0 and later,
                         and enables proper still image mode. avif=true alone
                         does not change pred_structure or hierarchical_levels
                         in SVT-AV1 4.0.1 — these must be set explicitly.
                         Without this patch SVT-AV1 uses pred=random_access,
                         mini-gop=4, PPCS=4 even for single still images,
                         causing higher memory usage and Firefox rejecting output.
                         With this patch expected log output is:
                           pred struct : all-intra
                           mini-gop size : 1
                           Number of PPCS : 1
                           fps : 1 / 1

--- libheif-1.21.2.orig/libheif/plugins/encoder_svt.cc	2026-03-20 14:24:11.498185705 +0000
+++ libheif-1.21.2/libheif/plugins/encoder_svt.cc	2026-03-20 14:24:20.931185592 +0000
@@ -838,8 +838,20 @@ static heif_error svt_start_sequence_enc
     // svt_config.force_key_frames = true; TODO: this does not seem to work (see all [1])
 
 #if 1
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+    switch (options->gop_structure) {
+      case heif_sequence_gop_structure_intra_only:
+        //svt_config.pred_structure = 1; // LOW_DELAY
+        break;
+      case heif_sequence_gop_structure_lowdelay:
+        //svt_config.pred_structure = 1; // LOW_DELAY
+        break;
+      case heif_sequence_gop_structure_unrestricted:
+        svt_config.pred_structure = 2; // RANDOM_ACCESS
+        break;
+    }
+#else
     // TODO: setting pref_structure to SVT_AV1_PRED_LOW_DELAY_B hangs the encoder
-
     switch (options->gop_structure) {
       case heif_sequence_gop_structure_intra_only:
         //svt_config.pred_structure = SvtAv1PredStructure::SVT_AV1_PRED_LOW_DELAY_B;
@@ -851,6 +863,7 @@ static heif_error svt_start_sequence_enc
         svt_config.pred_structure = SvtAv1PredStructure::SVT_AV1_PRED_RANDOM_ACCESS;
         break;
     }
+#endif
 
     if (options->keyframe_distance_max) {
       svt_config.intra_period_length = options->keyframe_distance_max; // TODO -1 ?
@@ -858,9 +871,18 @@ static heif_error svt_start_sequence_enc
 #endif
   }
   else {
-    // TODO: enable when https://gitlab.com/AOMediaCodec/SVT-AV1/-/issues/2245 is resolved
-    // svt_config.avif = true;
-    // encoder->still_image_mode = true;
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+    svt_config.avif = true;
+    encoder->still_image_mode = true;
+    // Force still image structure: single intra frame, no reordering buffers.
+    // avif=true alone does not change pred_structure or hierarchical_levels in
+    // SVT-AV1 4.0.1 — these must be set explicitly to get PPCS=1 and all-intra.
+    svt_config.pred_structure      = 0;  // LOW_DELAY_P — no B-frames, no reorder buffer
+    svt_config.hierarchical_levels = 0;  // flat, no mini-GOP pyramid (eliminates mini-gop=4)
+    svt_config.intra_period_length = -1; // all-intra: every frame is a keyframe
+    framerate_num   = 1;
+    framerate_denom = 1;
+#endif
   }
 
   if (color_format == EB_YUV422 || bitdepth_y > 10) {
@@ -920,7 +942,7 @@ static heif_error read_encoder_output_pa
 
         /* TODO: this is a hack
          * When using
-         *           svt_config.pred_structure = SvtAv1PredStructure::SVT_AV1_PRED_LOW_DELAY_B;
+         *           svt_config.pred_structure = 1; // LOW_DELAY
          * svt_av1_enc_get_packet() hangs on the second call. As a workaround, we can leave the
          * loop when we got the image:
          */
