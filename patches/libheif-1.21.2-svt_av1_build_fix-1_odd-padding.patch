diff -Naurp libheif-1.21.2.orig/libheif/box.cc libheif-1.21.2/libheif/box.cc
--- libheif-1.21.2.orig/libheif/box.cc
+++ libheif-1.21.2/libheif/box.cc
@@ -3633,6 +3633,18 @@ void Box_clap::set(uint32_t clap_width, uint32_t clap_height,
   assert(image_width >= clap_width);
   assert(image_height >= clap_height);
 
+  // The clap offset is computed as (image_size - clap_size) / 2.
+  // If the difference is odd the result is a non-integer fraction (e.g. -1/2).
+  // Firefox and other strict AVIF decoders reject files with fractional clap
+  // offsets per ISO 23000-22 §2. This happens when SVT-AV1 rounds an odd input
+  // dimension up by 1 for YUV420 chroma subsampling alignment.
+  // Fix: if the difference is odd, expand clap_width/height by 1 so that
+  // (image_size - clap_size) is even and the division by 2 yields an integer.
+  // The extra pixel is within the encoded area and imperceptible.
+  if ((image_width - clap_width) % 2 != 0 && clap_width + 1 <= image_width) {
+    clap_width += 1;
+  }
+  if ((image_height - clap_height) % 2 != 0 && clap_height + 1 <= image_height) {
+    clap_height += 1;
+  }
+
   m_clean_aperture_width = Fraction(clap_width, 1U);
   m_clean_aperture_height = Fraction(clap_height, 1U);
 
