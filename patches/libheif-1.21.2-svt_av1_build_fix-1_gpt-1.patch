@@ -855,9 +876,25 @@ static heif_error svt_start_sequence_encoding_intern(void* encoder_raw, const he
 #endif
   }
   else {
-    // TODO: enable when https://gitlab.com/AOMediaCodec/SVT-AV1/-/issues/2245 is resolved
-    // svt_config.avif = true;
-    // encoder->still_image_mode = true;
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+    // Proper still-image AVIF path for SVT-AV1 4.x
+    // Avoid LOW_DELAY because it may prepend Temporal Delimiter OBU in some paths.
+    // AVIF image items should not contain TD OBU. RANDOM_ACCESS + all-intra setup
+    // gives us a still-picture style bitstream without relying on post-strip hacks.
+    svt_config.avif = true;
+    encoder->still_image_mode = true;
+
+    // RANDOM_ACCESS in 4.x API
+    svt_config.pred_structure = 2;
+
+    // One-picture / all-intra style setup
+    svt_config.hierarchical_levels = 0;
+    svt_config.intra_period_length = -1;
+
+    // Stable single-frame timing metadata
+    framerate_num = 1;
+    framerate_denom = 1;
+#endif
   }

   if (color_format == EB_YUV422 || bitdepth_y > 10) {
@@ -917,6 +954,29 @@ static heif_error read_encoder_output_packets(void* encoder_raw, bool done_sendi
         output_packet.frameNr = output_buf->pts;
         output_packet.is_keyframe = (output_buf->pic_type == EbAv1PictureType::EB_AV1_KEY_PICTURE);

+        uint8_t* payload = data;
+        uint32_t payload_size = n;
+
+        // Safety net:
+        // If an SVT path still emits a leading Temporal Delimiter OBU, strip it.
+        // AVIF image items must not carry TD OBU.
+        //
+        // OBU header:
+        //   type = bits [6:3]
+        // TD OBU type == 2
+        //
+        // Most observed packets here use:
+        //   1 byte header + 1 byte leb128 payload-size(0)
+        // for TD, total 2 bytes.
+        //
+        // We only strip the exact simple leading TD pattern.
+        if (payload_size >= 2) {
+          uint8_t obu_type = (payload[0] >> 3) & 0x0F;
+          uint8_t has_size_field = (payload[0] >> 1) & 0x01;
+          if (obu_type == 2 && has_size_field == 1 && payload[1] == 0x00) {
+            payload += 2;
+            payload_size -= 2;
+          }
+        }
+
         encoder->output_packets.emplace_back(output_packet);
-        encoder->output_packets.back().compressedData.resize(n);
+        encoder->output_packets.back().compressedData.resize(payload_size);

         memcpy(encoder->output_packets.back().compressedData.data(),
-               data, n);
+               payload, payload_size);

