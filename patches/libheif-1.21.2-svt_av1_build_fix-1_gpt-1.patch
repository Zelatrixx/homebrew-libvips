Submitted By:            ChatGPT custom patch for SVT-AV1 4.0.1 + AVIF still image
Date:                    2026-03-20
Initial Package Version: 1.21.2
Upstream Status:         Not submitted
Origin:                  Based on libheif v1.21.2 + upstream PR #1680 direction, extended
Description:             Fixes libheif build/runtime with SVT-AV1 4.0.1+, enables proper still-image AVIF mode,
                         and avoids Firefox-incompatible output patterns by using AVIF still mode without TD OBU path.

--- a/libheif/plugins/encoder_svt.cc
+++ b/libheif/plugins/encoder_svt.cc
@@ -826,8 +826,16 @@ static heif_error svt_start_sequence_encoding_intern(void* encoder_raw, const he
   svt_config.tile_rows = int_log2(encoder->tile_rows);
   svt_config.tile_columns = int_log2(encoder->tile_cols);

 #if SVT_AV1_CHECK_VERSION(0, 9, 1)
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+  // SVT-AV1 4.x rejects SSIM tune together with libheif's CQP-style setup.
+  // Keep behavior stable for callers such as sharp/libvips and silently fall back.
+  svt_config.tune =
+      (encoder->tune == encoder_struct_svt::Tune_SSIM)
+          ? encoder_struct_svt::Tune_PSNR
+          : encoder->tune;
+#else
   svt_config.tune = encoder->tune;
 #endif
+#endif

   svt_config.enc_mode = (int8_t) encoder->speed;

