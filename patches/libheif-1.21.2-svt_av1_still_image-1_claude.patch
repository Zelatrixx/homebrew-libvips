+  // ==================================================================
+  // STILL IMAGE MODE — the core of this patch
+  // ------------------------------------------------------------------
+  // A still image is a single intra frame.  The SVT-AV1 encoder must
+  // be told explicitly:
+  //   intra_period_length = -1   → no inter prediction, ever
+  //   force_key_frames    = 1    → treat every frame as IDR/KEY
+  //   enable_tpl_la       = 0    → disable temporal lookahead (needs
+  //                                 >1 frame to be useful)
+  //   hierarchical_levels = 0    → flat prediction hierarchy
+  //   pred_structure      = LOW_DELAY_P → no B-frames, no reordering
+  //
+  // Without these settings SVT-AV1 defaults to a video GOP structure
+  // which may produce 'avis' (AVIF sequence) instead of 'avif'/'mif1'
+  // (AVIF still), violating ISO 23000-22 §6.
+  // ==================================================================
+  enc->svt_config.intra_period_length  = -1;
+  enc->svt_config.force_key_frames     = 1;
+  enc->svt_config.enable_tpl_la        = 0;
+  enc->svt_config.hierarchical_levels  = 0;
+  enc->svt_config.pred_structure       = SVT_AV1_PRED_LOW_DELAY_P;
+  enc->svt_config.level                = 0;   // auto
 
