   if (color_format == EB_YUV422 || bitdepth_y > 10) {
@@ -912,15 +939,24 @@ static heif_error read_encoder_output_pa
         output_packet.frameNr = output_buf->pts;
         output_packet.is_keyframe = (output_buf->pic_type == EbAv1PictureType::EB_AV1_KEY_PICTURE);
 
+        // Strip Temporal Delimiter OBU (type=2) from the bitstream.
+        // AVIF spec (ISO 23000-22 §2.1) forbids TD OBUs in image items.
+        // SVT-AV1 in low-delay mode prepends one; Firefox 136+ rejects such files.
+        uint32_t strip_bytes = 0;
+        if (n >= 2 && ((data[0] >> 3) & 0xF) == 2) {
+          // TD OBU header byte + has_size_field leb128 (size=0 → 1 byte) = 2 bytes total
+          strip_bytes = 2;
+        }
+
