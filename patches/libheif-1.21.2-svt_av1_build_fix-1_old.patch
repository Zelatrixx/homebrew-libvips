Submitted By:            Combined: Douglas R. Reno (build fix) + still image fps fix
Date:                    2026-03-20
Initial Package Version: 1.21.2
Upstream Status:         Pending
Origin:                  Upstream (PR #1680) + fps override for avif still image mode
Description:             Fixes building libheif with SVT-AV1 4.0 and later,
                         and enables proper still image mode (avif=true) with
                         correct framerate (1/1) so SVT-AV1 allocates minimal
                         buffers (PPCS=1) instead of video-oriented structures
                         (PPCS=4, mini-gop=4, pred=random_access).
                         Without the fps fix, avif=true is set but SVT-AV1 still
                         receives framerate_denom=25, causing video buffer layout
                         and Firefox to reject the output file.

diff -Naurp libheif-1.21.2.orig/libheif/plugins/encoder_svt.cc libheif-1.21.2/libheif/plugins/encoder_svt.cc
--- libheif-1.21.2.orig/libheif/plugins/encoder_svt.cc	2026-01-16 02:03:07.000000000 -0600
+++ libheif-1.21.2/libheif/plugins/encoder_svt.cc	2026-03-20 00:00:00.000000000 +0000
@@ -838,8 +838,20 @@ static heif_error svt_start_sequence_enc
     // svt_config.force_key_frames = true; TODO: this does not seem to work (see all [1])
 
 #if 1
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+    switch (options->gop_structure) {
+      case heif_sequence_gop_structure_intra_only:
+        //svt_config.pred_structure = 1; // LOW_DELAY
+        break;
+      case heif_sequence_gop_structure_lowdelay:
+        //svt_config.pred_structure = 1; // LOW_DELAY
+        break;
+      case heif_sequence_gop_structure_unrestricted:
+        svt_config.pred_structure = 2; // RANDOM_ACCESS
+        break;
+    }
+#else
     // TODO: setting pref_structure to SVT_AV1_PRED_LOW_DELAY_B hangs the encoder
-
     switch (options->gop_structure) {
       case heif_sequence_gop_structure_intra_only:
         //svt_config.pred_structure = SvtAv1PredStructure::SVT_AV1_PRED_LOW_DELAY_B;
@@ -851,6 +863,7 @@ static heif_error svt_start_sequence_enc
         svt_config.pred_structure = SvtAv1PredStructure::SVT_AV1_PRED_RANDOM_ACCESS;
         break;
     }
+#endif
 
     if (options->keyframe_distance_max) {
       svt_config.intra_period_length = options->keyframe_distance_max; // TODO -1 ?
@@ -858,9 +871,14 @@ static heif_error svt_start_sequence_enc
 #endif
   }
   else {
-    // TODO: enable when https://gitlab.com/AOMediaCodec/SVT-AV1/-/issues/2245 is resolved
-    // svt_config.avif = true;
-    // encoder->still_image_mode = true;
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+    svt_config.avif = true;
+    encoder->still_image_mode = true;
+    // Override framerate for still image: caller passes 1/25 but avif mode
+    // needs 1/1, otherwise SVT-AV1 allocates video-oriented buffer structures.
+    framerate_num   = 1;
+    framerate_denom = 1;
+#endif
   }
 
   if (color_format == EB_YUV422 || bitdepth_y > 10) {
@@ -920,7 +938,7 @@ static heif_error read_encoder_output_pa
 
         /* TODO: this is a hack
          * When using
-         *           svt_config.pred_structure = SvtAv1PredStructure::SVT_AV1_PRED_LOW_DELAY_B;
+         *           svt_config.pred_structure = 1; // LOW_DELAY
          * svt_av1_enc_get_packet() hangs on the second call. As a workaround, we can leave the
          * loop when we got the image:
          */
